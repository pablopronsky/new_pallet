rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isControlador() {
      return isSignedIn() && userRole() == 'controlador';
    }

    function isAllCovering() {
      return isSignedIn() && userRole() == 'allcovering';
    }

    function isVendedor() {
      return isSignedIn() && userRole() == 'vendedor';
    }

    function assignedBranch() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sucursalAsignada;
    }

    function hasAssignedBranch() {
      return assignedBranch() in ['gonnet', 'laplata', 'quilmes'];
    }

    function onlyDistributionSaleFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['cajasPorSucursal', 'updatedAt']);
    }

    function onlyAssignedBranchStockChanged() {
      return request.resource.data.cajasPorSucursal
        .diff(resource.data.cajasPorSucursal)
        .affectedKeys()
        .hasOnly([assignedBranch()]);
    }

    function assignedBranchStockDecreases() {
      return request.resource.data.cajasPorSucursal[assignedBranch()] is int
        && request.resource.data.cajasPorSucursal[assignedBranch()] >= 0
        && request.resource.data.cajasPorSucursal[assignedBranch()]
          <= resource.data.cajasPorSucursal[assignedBranch()];
    }

    function isVendedorDistributionSaleUpdate() {
      return isVendedor()
        && hasAssignedBranch()
        && onlyDistributionSaleFieldsChanged()
        && onlyAssignedBranchStockChanged()
        && assignedBranchStockDecreases();
    }

    // Users: each user can read their own profile. Admins can read/write all.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // Products: readable by app roles, only admin writes.
    // Note: Firestore cannot hide individual fields from a readable document.
    // For a stricter provider portal, expose supplier-safe aggregate/product
    // documents or a Cloud Function instead of raw productos.
    match /productos/{productId} {
      allow read: if isAdmin()
        || isControlador()
        || isVendedor()
        || isAllCovering();
      allow write: if isAdmin();
    }

    // Distribution: readable by app roles; admin + controlador may write
    // (controlador typically decreases their branch on sale; admin re-balances).
    // Vendedores may only decrement their assigned branch during sale creation.
    // This is an MVP client-side transaction; a Cloud Function/server action
    // should replace client-side stock mutation for stronger sale/update coupling.
    match /distribucion/{productId} {
      allow read: if isAdmin()
        || isControlador()
        || isVendedor()
        || isAllCovering();
      allow write: if isAdmin() || isControlador();
      allow update: if isVendedorDistributionSaleUpdate();
    }

    // Sales: signed-in can read; admin or controlador can create.
    // Vendedores can only create sales for their assigned branch.
    // Allcovering is read-only. This MVP computes provider totals client-side
    // from raw ventas; replace with supplier-safe aggregate documents or a
    // Cloud Function before exposing the portal beyond trusted supplier access.
    match /ventas/{saleId} {
      allow read: if isAdmin()
        || isControlador()
        || isAllCovering()
        || (isVendedor() && resource.data.sucursal == assignedBranch());
      allow create: if isAdmin()
        || isControlador()
        || (isVendedor()
          && request.resource.data.sucursal == assignedBranch());
      allow update, delete: if isAdmin();
    }

    // Audits: internal only. All Covering cannot read audit data.
    match /auditorias/{auditId} {
      allow read: if isAdmin() || isControlador();
      allow create: if isAdmin() || isControlador();
      allow update, delete: if isAdmin();
    }

    // App config: internal only. All Covering cannot read or edit config.
    match /config/{docId} {
      allow read: if isAdmin() || isControlador() || isVendedor();
      allow write: if isAdmin();
    }

    // Fallback: deny anything not matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
