rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDoc().data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isControlador() {
      return isSignedIn() && userRole() == 'controlador';
    }

    function isAllCovering() {
      return isSignedIn() && userRole() == 'allcovering';
    }

    function isVendedor() {
      return isSignedIn() && userRole() == 'vendedor';
    }

    function assignedBranch() {
      return userDoc().data.sucursalAsignada;
    }

    function hasAssignedBranch() {
      return assignedBranch() in ['gonnet', 'laplata', 'quilmes'];
    }

    function onlyDistributionSaleFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['cajasPorSucursal', 'updatedAt']);
    }

    function onlyAssignedBranchStockChanged() {
      return request.resource.data.cajasPorSucursal
        .diff(resource.data.cajasPorSucursal)
        .affectedKeys()
        .hasOnly([assignedBranch()]);
    }

    function assignedBranchStockDecreases() {
      return request.resource.data.cajasPorSucursal[assignedBranch()] is int
        && request.resource.data.cajasPorSucursal[assignedBranch()] >= 0
        && request.resource.data.cajasPorSucursal[assignedBranch()]
          <= resource.data.cajasPorSucursal[assignedBranch()];
    }

    function isVendedorDistributionSaleUpdate() {
      return isVendedor()
        && hasAssignedBranch()
        && onlyDistributionSaleFieldsChanged()
        && onlyAssignedBranchStockChanged()
        && assignedBranchStockDecreases();
    }

    function distributionBranchBoxesValid() {
      return request.resource.data.cajasPorSucursal.keys().hasOnly([
          'gonnet',
          'laplata',
          'quilmes'
        ])
        && request.resource.data.cajasPorSucursal.keys().hasAll([
          'gonnet',
          'laplata',
          'quilmes'
        ])
        && request.resource.data.cajasPorSucursal.gonnet is int
        && request.resource.data.cajasPorSucursal.gonnet >= 0
        && request.resource.data.cajasPorSucursal.laplata is int
        && request.resource.data.cajasPorSucursal.laplata >= 0
        && request.resource.data.cajasPorSucursal.quilmes is int
        && request.resource.data.cajasPorSucursal.quilmes >= 0;
    }

    function distributionTotal(data) {
      return data.cajasPorSucursal.gonnet
        + data.cajasPorSucursal.laplata
        + data.cajasPorSucursal.quilmes;
    }

    function isControladorDistributionMovementUpdate() {
      return isControlador()
        && onlyDistributionSaleFieldsChanged()
        && distributionBranchBoxesValid()
        && distributionTotal(request.resource.data) == distributionTotal(resource.data);
    }

    function isValidIngresoCreate() {
      return request.resource.data.keys().hasOnly([
          'productId',
          'sucursal',
          'cajas',
          'costoUSDPorCaja',
          'costoTotalUSD',
          'fecha',
          'createdBy',
          'notas',
          'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'productId',
          'sucursal',
          'cajas',
          'costoUSDPorCaja',
          'costoTotalUSD',
          'fecha',
          'createdBy',
          'createdAt'
        ])
        && request.resource.data.productId is string
        && request.resource.data.productId != ''
        && request.resource.data.sucursal in ['gonnet', 'laplata', 'quilmes']
        && request.resource.data.cajas is int
        && request.resource.data.cajas > 0
        && request.resource.data.costoUSDPorCaja is number
        && request.resource.data.costoUSDPorCaja > 0
        && request.resource.data.costoTotalUSD is number
        && request.resource.data.costoTotalUSD > 0
        && request.resource.data.fecha is timestamp
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && (!('notas' in request.resource.data)
          || request.resource.data.notas is string);
    }

    function isValidBajaCreate() {
      return request.resource.data.keys().hasOnly([
          'productId',
          'sucursal',
          'cajas',
          'motivo',
          'fecha',
          'createdBy',
          'notas',
          'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'productId',
          'sucursal',
          'cajas',
          'motivo',
          'fecha',
          'createdBy',
          'createdAt'
        ])
        && request.resource.data.productId is string
        && request.resource.data.productId != ''
        && request.resource.data.sucursal in ['gonnet', 'laplata', 'quilmes']
        && request.resource.data.cajas is int
        && request.resource.data.cajas > 0
        && request.resource.data.motivo in [
          'rotura',
          'perdida',
          'ajuste',
          'devolucion_proveedor',
          'otro'
        ]
        && request.resource.data.fecha is timestamp
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && (!('notas' in request.resource.data)
          || request.resource.data.notas is string);
    }

    function isValidTrasladoCreate() {
      return request.resource.data.keys().hasOnly([
          'productId',
          'sucursalOrigen',
          'sucursalDestino',
          'cajas',
          'fecha',
          'createdBy',
          'notas',
          'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'productId',
          'sucursalOrigen',
          'sucursalDestino',
          'cajas',
          'fecha',
          'createdBy',
          'createdAt'
        ])
        && request.resource.data.productId is string
        && request.resource.data.productId != ''
        && request.resource.data.sucursalOrigen in ['gonnet', 'laplata', 'quilmes']
        && request.resource.data.sucursalDestino in ['gonnet', 'laplata', 'quilmes']
        && request.resource.data.sucursalOrigen != request.resource.data.sucursalDestino
        && request.resource.data.cajas is int
        && request.resource.data.cajas > 0
        && request.resource.data.fecha is timestamp
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && (!('notas' in request.resource.data)
          || request.resource.data.notas is string);
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    match /productos/{productId} {
      // Controlador reads productos only to perform audits.
      allow read: if isAdmin() || isControlador() || isVendedor();
      allow write: if isAdmin();
    }

    match /distribucion/{productId} {
      // Controlador reads distribucion only to perform audits.
      allow read: if isAdmin() || isControlador() || isVendedor();

      allow create, delete: if isAdmin();
      allow update: if isAdmin();
      allow update: if isControladorDistributionMovementUpdate();

      allow update: if isVendedorDistributionSaleUpdate();
    }

    match /ventas/{saleId} {
      allow read: if isAdmin()
        || (isVendedor() && resource.data.sucursal == assignedBranch());

      allow create: if isAdmin()
        || (
          isVendedor()
          && hasAssignedBranch()
          && request.resource.data.sucursal == assignedBranch()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.cajas is int
          && request.resource.data.cajas > 0
        );

      allow update, delete: if isAdmin();
    }

    match /ingresos/{ingresoId} {
      allow read: if isAdmin();

      allow create: if isAdmin();

      allow update: if false;
      allow delete: if isAdmin();
    }

    match /bajas/{bajaId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /traslados/{trasladoId} {
      allow read: if isAdmin() || isControlador();
      allow create: if (isAdmin() || isControlador()) && isValidTrasladoCreate();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /proveedorResumen/{productId} {
      allow read: if isAdmin() || isAllCovering();
      allow write: if isAdmin();
    }

    match /auditorias/{auditId} {
      allow read: if isAdmin() || isControlador();
      allow create: if isAdmin() || isControlador();
      allow update, delete: if isAdmin();
    }

    match /config/{docId} {
      allow read: if isAdmin() || isVendedor();
      allow write: if isAdmin();
    }

    /*
      Fallback temporal para desarrollo:
      permite que admin lea/escriba cualquier colección no contemplada arriba.
      Más adelante, cuando terminemos Ingresos/Bajas/Exportar/Usuarios,
      conviene volver esto a false.
    */
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
